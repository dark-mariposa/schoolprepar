{% extends 'admin/base.html.twig' %}

{% block title %}Ajouter un Établissement - Admin{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_admin_etablissement_index') }}" class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold text-secondary">
            ⬅️ Retour à la liste
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-extrabold text-dark h2 mb-1">➕ Ajouter un Établissement</h1>
            <p class="text-muted small mb-0">Remplissez les informations ci-dessous pour enregistrer une nouvelle structure.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 style-form-container">
        <div class="card-body p-5">
            {# Correction du chemin de l'include vers le dossier admin/etablissement #}
            {{ include('admin/etablissement/_form.html.twig') }}
        </div>
    </div>
{% endblock %}