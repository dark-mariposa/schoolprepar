{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Établissements - Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-extrabold text-dark h2 mb-1">🏢 Gestion des Établissements</h1>
        <p class="text-muted small mb-0">Liste des structures scolaires et universitaires enregistrées.</p>
    </div>
    <div>
        <a href="{{ path('app_admin_etablissement_new') }}" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            ➕ Ajouter un établissement
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary text-uppercase fs-7 fw-bold">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Nom</th>
                        <th>Ville</th>
                        <th>Type</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-dark">
                {% for etablissement in etablissements %}
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#{{ etablissement.id }}</td>
                        <td class="fw-semibold">{{ etablissement.nom }}</td>
                        <td>{{ etablissement.ville }}</td>
                        <td><span class="badge bg-light text-dark border">{{ etablissement.type }}</span></td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('app_admin_etablissement_show', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-secondary">👁️</a>
                                <a href="{{ path('app_admin_etablissement_edit', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-primary">✏️</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <p class="mb-0 fs-5">Aucun établissement enregistré.</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}