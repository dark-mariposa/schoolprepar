{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form) }}
    <div class="mb-3 text-dark">
        {{ form_widget(form) }}
    </div>
    
    <div class="mt-4">
        <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
            💾 {{ button_label|default('Enregistrer les modifications') }}
        </button>
    </div>
{{ form_end(form) }}