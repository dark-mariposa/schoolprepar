{% extends 'admin/base.html.twig' %}

{% block title %}Ajouter une nouvelle Filière - Admin{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_admin_filiere_index') }}" class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold text-secondary">
            ⬅️ Retour à la liste
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-extrabold text-dark h2 mb-1">➕ Ajouter une Filière</h1>
            <p class="text-muted small mb-0">Remplissez les champs ci-dessous pour insérer une nouvelle formation dans la base de données.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 max-w-2xl">
        <div class="card-body p-5">
            {{ include('admin/filiere/_form.html.twig') }}
        </div>
    </div>
{% endblock %}