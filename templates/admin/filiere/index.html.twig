{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des Filières{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 text-gray-800">⚙️ Gestion des Filières</h1>
        <p class="text-muted">Liste des formations et filières d'études disponibles.</p>
    </div>
    <a href="{{ path('app_admin_filiere_new') }}" class="btn btn-primary rounded-pill px-4 shadow-sm">
        <i class="fas fa-plus"></i> Ajouter une filière
    </a>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase fs-7 fw-bold text-muted">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Débouchés</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for filiere in filieres %}
                    <tr>
                        <td class="ps-4 fw-bold text-secondary">#{{ filiere.id }}</td>
                        <td class="fw-bold text-dark">{{ filiere.nom }}</td>
                        <td>{{ filiere.description|slice(0, 60) }}...</td>
                        <td>{{ filiere.debouches|slice(0, 60) }}...</td>
                        <td class="text-end pe-4">
                            <a href="{{ path('app_admin_filiere_show', {'id': filiere.id}) }}" class="btn btn-sm btn-outline-secondary me-1">👁️</a>
                            <a href="{{ path('app_admin_filiere_edit', {'id': filiere.id}) }}" class="btn btn-sm btn-outline-primary">✏️</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="fas fa-folder-open fa-2x mb-3 d-block"></i>
                            Aucune filière enregistrée pour le moment.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}