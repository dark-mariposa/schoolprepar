{% extends 'admin/base.html.twig' %}

{% block title %}Modifier la Filière - Admin{% endblock %}

{% block body %}
    <div class="mb-4">
        <a href="{{ path('app_admin_filiere_index') }}" class="btn btn-sm btn-light border rounded-pill px-3 fw-semibold text-secondary">
            ⬅️ Retour à la liste
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-extrabold text-dark h2 mb-1">✏️ Modifier la Filière</h1>
            <p class="text-muted small mb-0">Modifiez les détails de la formation ci-dessous.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-5">
            {# CORRECTION DU CHEMIN ICI #}
            {{ include('admin/filiere/_form.html.twig', {'button_label': 'Mettre à jour la filière'}) }}
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 border-start border-danger border-4 text-dark">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <h5 class="text-danger fw-bold mb-1">Zone de danger</h5>
                <p class="text-muted small mb-0">Cette action supprimera définitivement cette filière de la base de données.</p>
            </div>
            {# CORRECTION DU CHEMIN ICI AUSSI #}
            {{ include('admin/filiere/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}