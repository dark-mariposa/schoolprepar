<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Administration - SchoolPrepar{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 px-0 bg-dark min-vh-100 shadow position-fixed">
                <div class="p-3 text-white">
                    <a href="{{ path('app_admin_dashboard') }}" class="text-decoration-none text-white">
                        <span class="fs-4 fw-bold">💼 Espace Admin</span>
                    </a>
                    <hr>
                    <ul class="nav nav-pills flex-column mb-auto gap-2">
                        <li class="nav-item">
                            <a href="{{ path('app_admin_dashboard') }}" class="nav-link text-white active shadow-sm">
                                📊 Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_filiere_index') }}" class="nav-link text-white-50 hover-light">
                                ⚙️ Gestion Filières
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('app_admin_etablissement_index') }}" class="nav-link text-white-50 hover-light">
                                🏫 Gestion Établissements
                            </a>
                        </li>
                    </ul>
                    <hr class="mt-5">
                    <a href="{{ path('app_front_home') }}" class="btn btn-sm btn-outline-light w-100 rounded-pill">
                        ⬅️ Retour au site
                    </a>
                </div>
            </div>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-5 py-4" style="margin-left: 16.66667%;">
                <div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom">
                    <h5 class="text-secondary fw-semibold">🛠️ Panel d'Administration</h5>
                    <span class="badge bg-danger px-3 py-2 rounded-pill font-monospace fw-bold">Mode Développeur</span>
                </div>

                {% block body %}{% endblock %}
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>