{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de Bord - SchoolPrepar{% endblock %}

{% block body %}
    <div class="mb-4">
        <h1 class="fw-bold text-dark">Tableau de bord SchoolPrepar</h1>
        <p class="text-muted">Bienvenue dans votre espace d'administration.</p>
    </div>
    
    <div class="row g-4 mt-2">
        <div class="col-sm-6 col-lg-4">
            <div class="card bg-info text-white border-0 shadow-sm rounded-4 p-3 h-100 card-stat">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="display-6 fw-bold mb-1">12</h3>
                        <p class="mb-0 fw-medium opacity-90">Filières enregistrées</p>
                    </div>
                    <span class="fs-1 opacity-75">⚙️</span>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-lg-4">
            <div class="card bg-success text-white border-0 shadow-sm rounded-4 p-3 h-100 card-stat">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="display-6 fw-bold mb-1">5</h3>
                        <p class="mb-0 fw-medium opacity-90">Établissements partenaires</p>
                    </div>
                    <span class="fs-1 opacity-75">🏫</span>
                </div>
            </div>
        </div>
    </div>

    <style>
        .card-stat {
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        }
        .card-stat:hover {
            transform: translateY(-4px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        }
    </style>
{% endblock %}