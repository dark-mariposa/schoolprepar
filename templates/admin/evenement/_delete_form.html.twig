<form method="post" action="{{ path('app_admin_evenement_delete', {'id': evenement.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet événement ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
    <button class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">🗑️ Supprimer</button>
</form>